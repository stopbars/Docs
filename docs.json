{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "BARS Docs",
  "colors": {
    "primary": "#fb2c36",
    "light": "#fb2c36",
    "dark": "#18181b"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Pilot Client",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "pilot-client/index",
              "pilot-client/installation",
              "pilot-client/config"
            ]
          }
        ]
      },
      {
        "tab": "EuroScope Plugin",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "euroscope/index",
              "euroscope/installation",
              "euroscope/config"
            ]
          },
          {
            "group": "Divisions",
            "pages": [
              "euroscope/guide"
            ]
          }
        ]
      },
      {
        "tab": "vatSys Plugin",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "vatsys/index",
              "vatsys/installation",
              "vatsys/config"
            ]
          },
          {
            "group": "Overview",
            "pages": [
              "vatsys/profiletypes",
              "vatsys/INTAS",
              "vatsys/legacy"
            ]
          }
        ]
      },
      {
        "tab": "BARS API",
        "openapi": "https://raw.githubusercontent.com/stopbars/Core/refs/heads/main/data/openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Discord",
          "href": "https://stopbars.com/discord",
          "icon": "discord"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/stopbars",
          "icon": "github"
        },
        {
          "anchor": "Open Collective",
          "href": "https://opencollective.com/stopbars",
          "icon": "hand-holding-dollar"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/banner.png",
    "dark": "/logo/banner.png"
  },
  "fonts": {
    "family": "Segoe UI"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "dark": "#09090b"
    }
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": false
    },
    "examples": {
      "languages": ["curl", "python", "javascript"],
      "defaults": "required"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Status",
        "href": "https://status.stopbars.com/"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/stopbars/Docs"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity"
   ]
  },
  "footer": {
    "socials": {
      "discord": "https://stopbars.com/discord",
      "github": "https://github.com/stopbars",
      "website": "https://opencollective.com/stopbars"
    }
  }
}
